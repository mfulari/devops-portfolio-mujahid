# Copy to terraform.tfvars and fill in.

aws_region  = "us-east-1"
project     = "hack-microservices"
environment = "demo"
owner       = "hackathon-team"

# --- Existing network (do not create) ---------------------------------------
vpc_id             = "vpc-xxxxxxxx"
private_subnet_ids = ["subnet-aaaa", "subnet-bbbb"]
public_subnet_ids  = ["subnet-cccc", "subnet-dddd"] # needed for public LoadBalancers

# --- EKS --------------------------------------------------------------------
cluster_name        = "hack-microservices-eks"
kubernetes_version  = "1.30"
node_instance_types = ["t3.medium"]
node_desired_size   = 2
node_min_size       = 1
node_max_size       = 3

# Optional: extra IAM roles that should get cluster-admin (e.g. your SSO role)
cluster_admin_role_arns = []

# --- GitHub OIDC ------------------------------------------------------------
github_org      = "your-github-org-or-user"
github_repo     = "hackpreparerepo"
github_branches = ["main"]

# Set to false if token.actions.githubusercontent.com OIDC provider
# already exists in your AWS account.
create_github_oidc_provider = true
